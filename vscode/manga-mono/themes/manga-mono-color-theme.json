  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6e7681", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword", "keyword.control", "keyword.operator.new",
        "storage.type", "storage.modifier"
      ],
      "settings": { "foreground": "#74b4ff" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function", "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#4a9eff" }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.type", "entity.name.class",
        "support.type", "support.class",
        "entity.other.inherited-class",
        "storage.type.class", "storage.type.struct",
        "keyword.type"
      ],
      "settings": { "foreground": "#d4a574" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#87a882" }
    },
    {
      "name": "Numbers & Booleans",
      "scope": [
        "constant.numeric", "constant.language.boolean",
        "constant.language.null", "constant.language.undefined"
      ],
      "settings": { "foreground": "#e09a5a" }
    },
    {
      "name": "Constants",
      "scope": [
        "constant", "constant.language",
        "variable.language.this", "variable.language.self"
      ],
      "settings": { "foreground": "#bf6a5e" }
    },
    {
      "name": "Special strings & Regex",
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": { "foreground": "#6fb3d6" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#e8eaed" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#b9c1cb" }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property", "support.variable.property",
        "entity.name.tag.css"
      ],
      "settings": { "foreground": "#b9c1cb" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#6fb3d6" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#9aa3ad" }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace", "entity.name.module",
        "support.other.namespace"
      ],
      "settings": { "foreground": "#d4a574" }
    },
    {
      "name": "Decorators / Attributes",
      "scope": [
        "entity.name.function.decorator", "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#e09a5a" }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#74b4ff" }
    },
    {
      "name": "HTML Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#4a9eff" }
    },
    {
      "name": "CSS Classes & IDs",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#d4a574" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#4a9eff" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#87a882" }
    },
    {
      "name": "Deprecated / Invalid",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#4a3f3f", "fontStyle": "strikethrough" }
    },
    {
      "name": "Markdown headings",
      "scope": ["markup.heading", "entity.name.section.markdown"],
      "settings": { "foreground": "#4a9eff", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#e8eaed", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#b9c1cb", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#87a882" }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#4a9eff" }
    },
    {
      "name": "Diff added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#87a882" }
    },
    {
      "name": "Diff removed",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#bf6a5e" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#4a9eff" }
    }
  ]
}
